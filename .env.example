# =============================================================================
# HR ASSISTANT AI AGENT - Environment Variables
# =============================================================================

# OpenAI / OpenRouter Compatible API Endpoint
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-120b:free
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small

# Discord Bot Settings
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_ALERT_CHANNEL_ID=your-channel-id-here

# User Authorization Whitelist (Comma-separated)
EMAIL_WHITELIST=falaq@example.com,user@example.com

# Service Configuration
NODE_ENV=production
HR_ASSISTANT_PORT=9004
QDRANT_PORT=9005