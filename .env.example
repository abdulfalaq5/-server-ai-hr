# =============================================================================
# HR ASSISTANT AI AGENT - Environment Variables Example
# =============================================================================

# LLM API (OpenRouter - for generating answers only)
# Embedding is handled locally by FastEmbed — no embedding API key needed
OPENAI_API_KEY=your-openrouter-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-120b:free

# Discord Bot Settings
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_ALERT_CHANNEL_ID=your-channel-id-here

# Discord Users allowed to use HR Assistant via DM (comma-separated Discord user IDs)
# Find user ID: Discord > Settings > Advanced > Developer Mode > Right-click user > Copy ID
DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432

# User Authorization Whitelist (comma-separated emails for /login command)
EMAIL_WHITELIST=yourname@example.com

# OpenClaw Gateway
# Token used by Discord Bot to authenticate with OpenClaw
# Change this to a long random string in production!
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
OPENCLAW_PORT=9002

# Service Configuration
NODE_ENV=production
HR_ASSISTANT_PORT=9004
QDRANT_PORT=9005